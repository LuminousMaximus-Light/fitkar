// ── Start server ───────────────────────────────────────────────────────────
app.listen(PORT, () => {
  console.log(`
╔══════════════════════════════════╗
║   FitKar AI Backend Running      ║
║   http://localhost:${PORT}          ║
║   Token: ${REPLICATE_TOKEN ? '✅ configured' : '❌ missing'}           ║
╚══════════════════════════════════╝
  `);
  if (!REPLICATE_TOKEN) {
    console.warn('⚠️  Set REPLICATE_API_TOKEN env variable to enable AI try-on.');
    console.warn('   Get your token at: https://replicate.com/account/api-tokens');
  }
});
